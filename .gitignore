__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ===== Datos pesados (imágenes y videos): NO versionar =====
data/raw/images/*
data/raw/videos/*
data/frames/all/*
data/frames/selected/*
data/dataset_yolo/images/train/*
data/dataset_yolo/images/val/*
data/dataset_yolo/images/test/*
# El dataset_yolo es DERIVADO (se regenera con build_baseline_dataset.py a
# partir de data/labeling_subset/*.txt, que sí se versionan). No versionamos
# el split para evitar duplicar el trabajo manual y ensuciar el repo.
data/dataset_yolo/labels/train/*
data/dataset_yolo/labels/val/*
data/dataset_yolo/labels/test/*
*.cache
# Dataset de ablación y backups (derivados/regenerables)
data/dataset_yolo_half/
data/data_half.yaml
data/labeling_subset_backup/

# Excluir SOLO imágenes en carpetas de etiquetado (las .txt SI van)
data/labeling/*.jpg
data/labeling/*.jpeg
data/labeling/*.png
data/labeling/*.bmp
data/labeling/*.webp
data/labeling_subset/*.jpg
data/labeling_subset/*.jpeg
data/labeling_subset/*.png
data/labeling_subset/*.bmp
data/labeling_subset/*.webp
